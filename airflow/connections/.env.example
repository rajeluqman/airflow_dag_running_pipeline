# Local/codespace secrets-backend resolution (Airflow's built-in EnvironmentVariablesBackend).
#
# Copy this file to `airflow/connections/.env` (gitignored — see .gitignore's
# `**/connections/*.env` rule) and fill in real values to run Airflow locally from Fasa 2
# onward. The conn_id strings below match airflow/connections/connection_ids.py exactly — they
# are the ONLY thing a DAG ever references. In MWAA, the same conn_id strings resolve instead
# via AIRFLOW__SECRETS__BACKEND=...SecretsManagerBackend — zero DAG code change. Full design:
# architecture/SECRETS_BACKEND.md.

AIRFLOW_CONN_GLUE_HOME_CREDIT=aws://
AIRFLOW_CONN_DATABRICKS_OLIST=databricks://
AIRFLOW_CONN_DATABRICKS_PAYSIM=databricks://
AIRFLOW_CONN_DATABRICKS_VOLVE=databricks://
AIRFLOW_CONN_SNOWFLAKE_CIL=snowflake://
